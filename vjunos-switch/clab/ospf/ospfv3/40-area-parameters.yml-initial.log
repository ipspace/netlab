y interfaces) or SLAAC (if the device is a router)\n#\nip link set eth1 down\nsysctl -qw net.ipv6.conf.eth1.autoconf=0\nsysctl -qw net.ipv6.conf.eth1.accept_ra=0\nip link set dev eth1 mtu 1500\nip link set eth1 up\nip link set eth2 down\nsysctl -qw net.ipv6.conf.eth2.autoconf=0\nsysctl -qw net.ipv6.conf.eth2.accept_ra=0\nip link set dev eth2 mtu 1500\nip link set eth2 up\nip link set eth3 down\nsysctl -qw net.ipv6.conf.eth3.autoconf=0\nsysctl -qw net.ipv6.conf.eth3.accept_ra=0\nip link set dev eth3 mtu 1500\nip link set eth3 up\nip link set eth4 down\nsysctl -qw net.ipv6.conf.eth4.autoconf=0\nsysctl -qw net.ipv6.conf.eth4.accept_ra=0\nip link set dev eth4 mtu 1500\nip link set eth4 up\n\n#\n# Add vtysh.conf file\necho \"service integrated-vtysh-config\" >/etc/frr/vtysh.conf\n\n#\n# Rest of initial configuration done through VTYSH\n#\ncat >/tmp/config <<CONFIG\nhostname r11\n!\nlog file /tmp/logging\n\n!\nipv6 forwarding\nvrf mgmt\n exit-vrf\n!\nfrr defaults datacenter\n!\ninterface lo\n no shutdown\n ! no ip address\n ipv6 address 2001:db8:1::2/128\n!\ninterface eth1\n no shutdown\n description r11 -> dut\n ! no ip address\n ipv6 address 2001:db8:3::2/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ninterface eth2\n no shutdown\n description r11 -> stub [stub]\n ! no ip address\n ipv6 address 2001:db8:cafe:2001::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ninterface eth3\n no shutdown\n description r11 -> stub [stub]\n ! no ip address\n ipv6 address 2001:db8:cafe:2002::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ninterface eth4\n no shutdown\n description r11 -> stub [stub]\n ! no ip address\n ipv6 address 2001:db8:cafe:3002::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ndo write\nCONFIG\nvtysh -f /tmp/config\n!\nexit 0\n"
