    #!/bin/sh
    #
    set -e
    set -x
  
    hostname r
    #
    # Build hosts file
    #
    #
    cat <<SCRIPT >/tmp/hosts
    #
    # Created by netlab initial
    #
    172.16.0.1 h1 eth1.h1
    2001:db8:1::1 h1 eth1.h1
    172.16.1.2 h2 eth1.h2
    2001:db8:1:1::2 h2 eth1.h2
    172.16.2.3 h3 eth1.h3
    2001:db8:1:2::3 h3 eth1.h3
    10.0.0.132 r
    2001:db8:0:84::1 r
    172.16.0.132 vio1.r
    2001:db8:1::84 vio1.r
    172.16.1.132 vio2.r
    2001:db8:1:1::84 vio2.r
    172.16.2.132 vio3.r
    2001:db8:1:2::84 vio3.r
    SCRIPT
    grep "Created by netlab" /etc/hosts || uniq /tmp/hosts >>/etc/hosts
  
    #
    # Enable forwarding
    #
    sysctl net.inet.ip.forwarding=1
    sysctl net.inet6.ip6.forwarding=1
    echo -n > /etc/rad.conf
  
    #
    # Interface configuration
    #
    ifconfig lo0 inet 10.0.0.132/32 alias
    echo interface lo0 >> /etc/rad.conf
    ifconfig lo0 inet6 2001:db8:0:84::1/64
  
    ifconfig vio1 -inet
    ifconfig vio1 -inet6
    ifconfig vio1 inet 172.16.0.132/24
    echo interface vio1 >> /etc/rad.conf
    ifconfig vio1 inet6 2001:db8:1::84/64
    ifconfig vio1 description "r -> h1"
  
    ifconfig vio2 -inet
    ifconfig vio2 -inet6
    ifconfig vio2 inet 172.16.1.132/24
    echo interface vio2 >> /etc/rad.conf
    ifconfig vio2 inet6 2001:db8:1:1::84/64
    ifconfig vio2 description "r -> h2"
  
    ifconfig vio3 -inet
    ifconfig vio3 -inet6
    ifconfig vio3 inet 172.16.2.132/24
    echo interface vio3 >> /etc/rad.conf
    ifconfig vio3 inet6 2001:db8:1:2::84/64
    ifconfig vio3 description "r -> h3"
    ifconfig vio3 down
  
  
    #
    # (re-)start RA daemon
    #
    pkill -q rad || true
    rad

