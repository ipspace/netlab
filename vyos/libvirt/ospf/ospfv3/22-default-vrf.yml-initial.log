top\nedit vrf name d1\n\n\nset protocols bgp system-as 65000\n\nset protocols bgp parameters router-id 10.0.0.1\n\nset protocols bgp address-family ipv6-unicast rd vpn export 65000:1\nset protocols bgp address-family ipv6-unicast route-target vpn import \"65000:1\"\nset protocols bgp address-family ipv6-unicast route-target vpn export \"65000:1\"\nset protocols bgp address-family ipv6-unicast import vpn\nset protocols bgp address-family ipv6-unicast export vpn\nset protocols bgp address-family ipv6-unicast label vpn export auto\n\n\n\nset protocols bgp address-family ipv6-unicast redistribute connected\nset protocols bgp address-family ipv6-unicast redistribute ospfv3\n\n# Define networks for VRF Loopback\n\n\n\nset protocols ospfv3 parameters router-id 10.0.0.1\n\nset protocols ospfv3 redistribute bgp\nset protocols ospfv3 redistribute connected\n\n\nset protocols ospfv3 default-information originate\n\nset protocols ospfv3 default-information originate always\n\n\n\n\n\n\n\n\nset protocols ospfv3 interface eth1 area 0.0.0.0\n\nset protocols ospfv3 interface eth1 network point-to-point\n\n\n# Back to root level\ntop\n\n# Commit, save and exit from subshell\n\ncommit\nsave\nexit\n"
