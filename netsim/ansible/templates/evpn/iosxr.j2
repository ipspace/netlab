{#
  Cisco IOS/XR EVPN control-plane and MAC-VRF/IP-VRF configuration
#}
{% if vlans is defined %}
{%   for vname,vlan in vlans.items() if vlan.evpn.evi is defined %}
{%     if loop.first %}
evpn
{%     endif %}
{%     set vlan = vlans[vname] %}
  evi {{ vlan.evpn.evi }}
    advertise-mac
    bgp
{%     if vlan.evpn.rd is defined %}
      rd {{ vlan.evpn.rd }}
{%     endif %}
{%     for irt in vlan.evpn.import|default([]) %}
      route-target import {{ irt }}
{%     endfor %}
{%     for ert in vlan.evpn.export|default([]) %}
      route-target export {{ ert }}
{%     endfor %}
{%   endfor %}
{%   for vname,vlan in vlans.items() if vlan.evpn.evi is defined %}
{%     if loop.first %}
!
l2vpn
  bridge group netlab
{%     endif %}
{%     set vlan = vlans[vname] %}
    bridge-domain BD{{ vlan.id }}
      evi {{ vlan.evpn.evi }}
{%   endfor %}
{% endif %}
!
router bgp {{ bgp.as }}
{#
   If we have EVPN IP VRFs ensure the VPNv4/VPNv6 address families are configured
   (that's how IOS/XR generates type-5 routes
#}
{% for af in ['ipv4','ipv6'] if vrfs is defined %}
{%   for vname,vdata in vrfs.items() if vdata.evpn.evi is defined and af in vdata.af %}
{%     if loop.first %}
  address-family vpn{{ af.replace('ip','') }} unicast
    bgp scan-time 5
    bgp import-delay 0 0
{%     endif %}
{%   endfor %}
{% endfor %}
  address-family l2vpn evpn
    bgp scan-time 5
{% for n in bgp.neighbors if n.evpn|default(False) %}
  neighbor {{ n[n.evpn] }}
    address-family l2vpn evpn
{%   if 'ebgp' in n.type %}
      send-community-ebgp
      send-extended-community-ebgp
{%   endif %}
{%   if n.rr_client|default(False) %}
      route-reflector-client
{%   endif %}
{#
   If we have at least one EVPN IP VRF, we have to advertise corresponding VPNvx
   routes into EVPN address family... PER NEIGHBOR ¯\_(ツ)_/¯
#}
{%   for af in ['ipv4','ipv6'] if vrfs is defined %}
{%     for vname,vdata in vrfs.items() if vdata.evpn.evi is defined and af in vdata.af %}
{%       if loop.first %}
      advertise vpn{{ af.replace('ip','') }} unicast
{%       endif %}
{%     endfor %}
{%   endfor %}
{% endfor %}
