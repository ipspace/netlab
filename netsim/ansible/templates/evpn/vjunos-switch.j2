{#
  vJunos-switch (Junos) EVPN configuration

  Supports both 'default_macvrf' mode (global protocols evpn) and
  per-VLAN mac-vrf routing-instances.
#}

{% if vxlan is defined and evpn._junos_default_macvrf|default(False) %}
protocols {
  evpn {
    encapsulation vxlan;
    default-gateway no-gateway-community;
    extended-vni-list all;
{% if vxlan.vlans is defined %}
    vni-options {
{%   for vname in vxlan.vlans if vlans[vname].vni is defined %}
{%     set vlan = vlans[vname] %}
        vni {{ vlan.vni }} {
            vrf-target target:{{ vlan.evpn.import[0] }};
        }
{%   endfor %}
    }
{% endif %}
  }
}
{% endif %}

{# Common Junos EVPN configuration (BGP neighbors, MAC-VRF, L3VNI, policy-options) #}
{% include 'junos/common.j2' %}
{# Common vlan configuration #}
{% if vlans is defined and vxlan is defined and not evpn._junos_default_macvrf|default(False) %}
{% include 'junos/vlan.j2' %}
{% endif %}

