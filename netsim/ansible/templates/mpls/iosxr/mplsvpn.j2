!
router bgp {{ bgp.as }}
!
! Initialize VPN AFs
!
{% for af in ['ipv4','ipv6'] if mpls.vpn[af] is defined %}
{%   set vpnaf = 'vpn' + af.replace('ip','') %}
{%   for n in bgp.neighbors if vpnaf in n %}
{%     if loop.first %}
  address-family {{ vpnaf }} unicast
    bgp scan-time 5
    bgp import-delay 0 0
{%     endif %}
{%   endfor %}
{% endfor %}
!
! Enable VPN AFs on BGP neighbors
!
{% for n in bgp.neighbors %}
{%   for af in ['ipv4','ipv6'] if mpls.vpn[af] is defined and 'vpn'+af.replace('ip','') in n %}
{%   set vpnaf = 'vpn' + af.replace('ip','') %}
  neighbor {{ n[vpnaf] }}
    address-family {{ vpnaf }} unicast
{%     if n.rr_client|default(False) %}
      route-reflector-client
{%     endif %}
{%     if 'ebgp' in n.type %}
      send-community-ebgp
      send-extended-community-ebgp
{%     endif %}
{%   endfor %}
{% endfor %}
