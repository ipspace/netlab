{% for pname,pdata in routing.policy|dictsort %}
!
route-policy {{ pname }}
{%   for p_entry in pdata %}
{#     Process set statements
#}
{%     include 'iosxr/policy-match.j2' %}
{%     include 'iosxr/policy-set.j2' %}
{%     include 'iosxr/policy-delete.j2' %}
{#
       Process action
#}
{%     if p_entry.action|default('permit') == 'deny' %}
    drop
{%     else %}
{%       if 'set' not in p_entry and 'delete' not in p_entry %}
    pass
{%       endif %}
{#       Emulate route maps -- every matching entry concludes the processing #}
{%       if not loop.last %}
    done
{%       endif %}
{%     endif %}
{%     if p_entry.match|default(False) %}
  endif
{%     endif -%}
{%   endfor -%}
end-policy
{% endfor %}
