{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Netlab Consolidated JSON Cache Schema",
  "description": "Schema for validating consolidated JSON cache files created by netlab consolidate",
  "type": "object",
  "required": ["version", "netlab_version", "files", "file_count"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version of the consolidated cache",
      "pattern": "^\\d+\\.\\d+$"
    },
    "netlab_version": {
      "type": "string",
      "description": "Netlab version that created this cache (e.g., '25.12.02'). Cache is invalid if this doesn't match the current netlab version.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "topology_file": {
      "oneOf": [
        {"type": "string"},
        {"type": "null"}
      ],
      "description": "Path to the original topology file that was consolidated (null if consolidating all system files)"
    },
    "files": {
      "type": "object",
      "description": "Dictionary mapping file paths to their content",
      "patternProperties": {
        ".*": {
          "type": "object",
          "required": ["content", "source"],
          "properties": {
            "content": {
              "description": "Parsed YAML content as a dictionary/object",
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "message": {
                  "type": "string",
                  "description": "Topology description message"
                },
                "groups": {
                  "type": "object",
                  "description": "Node groups definition",
                  "additionalProperties": true
                },
                "nodes": {
                  "oneOf": [
                    {
                      "type": "object",
                      "description": "Node definitions object",
                      "additionalProperties": true
                    },
                    {
                      "type": "array",
                      "description": "Node names array",
                      "items": {"type": "string"}
                    }
                  ],
                  "description": "Node definitions (object) or node names (array)"
                },
                "links": {
                  "oneOf": [
                    {
                      "type": "array",
                      "description": "Link definitions array",
                      "items": {
                        "oneOf": [
                          {"type": "object"},
                          {"type": "string"}
                        ]
                      }
                    },
                    {"type": "null", "description": "No links defined"}
                  ],
                  "description": "Link definitions (array or null)"
                },
                "vlans": {
                  "type": "object",
                  "description": "VLAN definitions",
                  "additionalProperties": true
                },
                "vrfs": {
                  "type": "object",
                  "description": "VRF definitions",
                  "additionalProperties": true
                },
                "bgp": {
                  "type": "object",
                  "description": "BGP configuration",
                  "additionalProperties": true
                },
                "ospf": {
                  "type": "object",
                  "description": "OSPF configuration",
                  "additionalProperties": true
                },
                "isis": {
                  "type": "object",
                  "description": "IS-IS configuration",
                  "additionalProperties": true
                },
                "evpn": {
                  "type": "object",
                  "description": "EVPN configuration",
                  "additionalProperties": true
                },
                "vxlan": {
                  "type": "object",
                  "description": "VXLAN configuration",
                  "additionalProperties": true
                },
                "validate": {
                  "oneOf": [
                    {
                      "type": "object",
                      "description": "Validation rules object",
                      "additionalProperties": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    {
                      "type": "array",
                      "description": "Validation paths array",
                      "items": {"type": "string"}
                    }
                  ],
                  "description": "Validation rules (object) or validation paths (array)"
                },
                "description": {
                  "type": "string",
                  "description": "File or component description"
                },
                "config": {
                  "oneOf": [
                    {"type": "object", "additionalProperties": true},
                    {"type": "array", "items": {"type": "object", "additionalProperties": true}},
                    {"type": "string"}
                  ],
                  "description": "Configuration settings (object, array of objects, or string)"
                },
                "template": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "boolean"}
                  ],
                  "description": "Template file path or boolean flag"
                },
                "version": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "number"}
                  ],
                  "description": "Version number or string"
                },
                "module": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "array", "items": {"type": "string"}}
                  ],
                  "description": "Module name or list of modules"
                },
                "device": {
                  "type": "string",
                  "description": "Device type"
                },
                "provider": {
                  "type": "string",
                  "description": "Provider type"
                },
                "defaults": {
                  "type": "object",
                  "description": "Default settings",
                  "additionalProperties": true
                },
                "features": {
                  "type": "object",
                  "description": "Feature flags",
                  "additionalProperties": true
                },
                "capabilities": {
                  "type": "object",
                  "description": "Device capabilities",
                  "additionalProperties": true
                },
                "attributes": {
                  "type": "object",
                  "description": "Attribute definitions",
                  "additionalProperties": true
                },
                "clab": {
                  "type": "object",
                  "description": "Containerlab configuration",
                  "additionalProperties": true
                },
                "libvirt": {
                  "type": "object",
                  "description": "Libvirt configuration",
                  "additionalProperties": true
                },
                "virtualbox": {
                  "type": "object",
                  "description": "VirtualBox configuration",
                  "additionalProperties": true
                },
                "external": {
                  "type": "object",
                  "description": "External configuration",
                  "additionalProperties": true
                },
                "docker": {
                  "type": "object",
                  "description": "Docker configuration",
                  "additionalProperties": true
                },
                "graphite": {
                  "type": "object",
                  "description": "Graphite configuration",
                  "additionalProperties": true
                },
                "group_vars": {
                  "type": "object",
                  "description": "Ansible group variables",
                  "additionalProperties": true
                },
                "interface_name": {
                  "type": "string",
                  "description": "Interface naming pattern"
                },
                "loopback_interface_name": {
                  "type": "string",
                  "description": "Loopback interface naming pattern"
                },
                "lag_interface_name": {
                  "type": "string",
                  "description": "LAG interface naming pattern"
                },
                "tunnel_interface_name": {
                  "type": "string",
                  "description": "Tunnel interface naming pattern"
                },
                "mgmt_if": {
                  "type": "string",
                  "description": "Management interface name"
                },
                "ifindex_offset": {
                  "type": "integer",
                  "description": "Interface index offset"
                },
                "mtu": {
                  "type": "integer",
                  "description": "Maximum transmission unit"
                },
                "role": {
                  "type": "string",
                  "description": "Node or device role"
                },
                "node": {
                  "type": "object",
                  "description": "Node configuration",
                  "additionalProperties": true
                },
                "parent": {
                  "type": "string",
                  "description": "Parent reference"
                },
                "runtime": {
                  "type": "string",
                  "description": "Runtime configuration"
                },
                "support": {
                  "oneOf": [
                    {"type": "object", "additionalProperties": true},
                    {"type": "null"}
                  ],
                  "description": "Support information or null"
                },
                "warnings": {
                  "type": "object",
                  "description": "Warning messages",
                  "additionalProperties": true
                },
                "transform_after": {
                  "type": "array",
                  "description": "Post-transformation hooks",
                  "items": {"type": "string"}
                },
                "config_after": {
                  "type": "array",
                  "description": "Post-configuration hooks",
                  "items": {"type": "string"}
                },
                "no_propagate": {
                  "oneOf": [
                    {"type": "array", "items": {"type": "string"}},
                    {"type": "object", "additionalProperties": true}
                  ],
                  "description": "No-propagate settings"
                },
                "routing": {
                  "type": "object",
                  "description": "Routing configuration",
                  "additionalProperties": true
                },
                "bfd": {
                  "type": "object",
                  "description": "BFD configuration",
                  "additionalProperties": true
                },
                "requires": {
                  "type": "array",
                  "description": "Required dependencies",
                  "items": {"type": "string"}
                },
                "start": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "array", "items": {"type": "string"}}
                  ],
                  "description": "Start command or script"
                },
                "stop": {
                  "oneOf": [
                    {"type": "string"},
                    {"type": "array", "items": {"type": "string"}}
                  ],
                  "description": "Stop command or script"
                },
                "probe": {
                  "type": "array",
                  "description": "Probe commands",
                  "items": {
                    "oneOf": [
                      {"type": "string"},
                      {"type": "object", "additionalProperties": true}
                    ]
                  }
                },
                "cleanup": {
                  "type": "array",
                  "description": "Cleanup commands",
                  "items": {"type": "string"}
                },
                "_meta_device": {
                  "type": "boolean",
                  "description": "Meta device flag"
                },
                "_top": {
                  "type": "object",
                  "description": "Top-level modifications",
                  "additionalProperties": true
                },
                "loopback": {
                  "oneOf": [
                    {"type": "object", "additionalProperties": true},
                    {"type": "boolean"}
                  ],
                  "description": "Loopback configuration"
                }
              }
            },
            "source": {
              "type": "string",
              "description": "Original source filename/path"
            },
            "package": {
              "type": "boolean",
              "description": "Whether this is a package file (package: prefix)"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "file_count": {
      "type": "integer",
      "description": "Number of files in the cache",
      "minimum": 0
    }
  },
  "additionalProperties": false
}

