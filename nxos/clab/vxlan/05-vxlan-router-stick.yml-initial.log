>/etc/frr/vtysh.conf\n\n#\n# Rest of initial configuration done through VTYSH\n#\ncat >/tmp/config <<CONFIG\nhostname s1\n!\nlog file /tmp/logging\n\n!\nip forwarding\nvrf mgmt\n exit-vrf\n!\nfrr defaults datacenter\n!\ninterface lo\n no shutdown\n ip address 10.0.0.1/32\n!\ninterface eth1\n no shutdown\n description s1 -> ros\n ip address 10.1.0.2/30\n!\ninterface eth2\n no shutdown\n description [Access VLAN red] s1 -> h1\n ! no ip address\n!\ninterface eth3\n no shutdown\n description [Access VLAN blue] s1 -> h2\n ! no ip address\n!\ninterface vlan1000\n no shutdown\n description VLAN red (1000) -> [h1,ros]\n ! no ip address\n!\ninterface vlan1001\n no shutdown\n description VLAN blue (1001) -> [h2,ros]\n ! no ip address\n!\ndo write\nCONFIG\nvtysh -f /tmp/config\n!\nexit 0\n"
