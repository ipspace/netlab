ok: [r] => 
  msg: |-
    initial configuration for r
    =========================================
    #!/bin/bash
    #
    set -e
    set -x
    #
    # Create bash profile script
    #
    cat <<SCRIPT >/root/.bash_profile
    #!/bin/bash
    #
    export PS1="\h(bash)# "
    echo "Use vtysh to connect to FRR daemon"
    echo
    SCRIPT
    cat <<SCRIPT >.bash_profile
    #!/bin/bash
    #
    export PS1="\h(bash)$ "
    echo "Use sudo vtysh to connect to FRR daemon"
    echo
    SCRIPT
  
    #
    # Build hosts file
    #
    #
    cat <<SCRIPT >/tmp/hosts
    #
    # Created by netlab initial
    #
    172.16.0.1 h1 eth1.h1
    2001:db8:1::1 h1 eth1.h1
    172.16.1.2 h2 eth1.h2
    2001:db8:1:1::2 h2 eth1.h2
    172.16.2.3 h3 eth1.h3
    2001:db8:1:2::3 h3 eth1.h3
    10.0.0.132 r
    2001:db8:0:84::1 r
    172.16.0.132 Ethernet0.r
    2001:db8:1::84 Ethernet0.r
    172.16.1.132 Ethernet4.r
    2001:db8:1:1::84 Ethernet4.r
    172.16.2.132 Ethernet8.r
    2001:db8:1:2::84 Ethernet8.r
    SCRIPT
    grep "Created by netlab" /etc/hosts || uniq /tmp/hosts >>/etc/hosts
    #
    # Disable IPv6 (for IPv4-only interfaces) or SLAAC (if the device is a router)
    #
    #
    # Configure interfaces
    #
    config hostname r
    if ip link|grep Loopback0; then
      echo Loopback0 already exists
    else
      config loopback add Loopback0
    fi
    if show ip interface|grep Loopback0|grep 10.0.0.132/32; then
      echo 10.0.0.132/32 already configured on Loopback0
    else
      config interface ip add Loopback0 10.0.0.132/32
    fi
    if show ipv6 interface|grep Loopback0|grep 2001:db8:0:84::1/64; then
      echo 2001:db8:0:84::1/64 already configured on Loopback0
    else
      config interface ip add Loopback0 2001:db8:0:84::1/64
    fi
    !
    if show ip interface|grep Ethernet0|grep 172.16.0.132/24; then
      echo 172.16.0.132/24 already configured on Ethernet0
    else
      config interface ip add Ethernet0 172.16.0.132/24
    fi
    config interface ipv6 enable use-link-local-only Ethernet0
    if show ipv6 interface|grep Ethernet0|grep 2001:db8:1::84/64; then
      echo 2001:db8:1::84/64 already configured on Ethernet0
    else
      config interface ip add Ethernet0 2001:db8:1::84/64
    fi
    config interface mtu Ethernet0 1548
    !
    if show ip interface|grep Ethernet4|grep 172.16.1.132/24; then
      echo 172.16.1.132/24 already configured on Ethernet4
    else
      config interface ip add Ethernet4 172.16.1.132/24
    fi
    config interface ipv6 enable use-link-local-only Ethernet4
    if show ipv6 interface|grep Ethernet4|grep 2001:db8:1:1::84/64; then
      echo 2001:db8:1:1::84/64 already configured on Ethernet4
    else
      config interface ip add Ethernet4 2001:db8:1:1::84/64
    fi
    config interface mtu Ethernet4 1548
    !
    if show ip interface|grep Ethernet8|grep 172.16.2.132/24; then
      echo 172.16.2.132/24 already configured on Ethernet8
    else
      config interface ip add Ethernet8 172.16.2.132/24
    fi
    config interface ipv6 enable use-link-local-only Ethernet8
    if show ipv6 interface|grep Ethernet8|grep 2001:db8:1:2::84/64; then
      echo 2001:db8:1:2::84/64 already configured on Ethernet8
    else
      config interface ip add Ethernet8 2001:db8:1:2::84/64
    fi
    config interface mtu Ethernet8 1548
    !
    #
    # Rest of initial configuration done through VTYSH
    # Make sure it's ready
    #
    if vtysh -c 'show running' >/dev/null; then
      echo vtysh is ready
    else
      echo 'giving vtysh some more time :('
      sleep 5
    fi
    #
    # And now let's configure the interfaces
    #
    cat >/etc/sonic/frr/do_config <<CONFIG
    hostname r
    !
    ipv6 forwarding
    !
    interface Loopback0
     no shutdown
    !
    interface Ethernet0
     no shutdown
     description r -> h1 [stub]
     ipv6 nd ra-interval 5
     no ipv6 nd suppress-ra
     bandwidth 1000
    !
    interface Ethernet4
     no shutdown
     description r -> h2 [stub]
     ipv6 nd ra-interval 5
     no ipv6 nd suppress-ra
     bandwidth 2000
    !
    interface Ethernet8
     no shutdown
     description r -> h3 [stub]
     ipv6 nd ra-interval 5
     no ipv6 nd suppress-ra
    !
    do write
    CONFIG
    docker exec bgp vtysh -f /etc/frr/do_config
    exit 0

