link set dev eth3 mtu 1500\nip link set eth3 up\nip link set eth4 down\nsysctl -qw net.ipv6.conf.eth4.autoconf=0\nsysctl -qw net.ipv6.conf.eth4.accept_ra=0\nip link set dev eth4 mtu 1500\nip link set eth4 up\nip link set eth5 down\nsysctl -qw net.ipv6.conf.eth5.autoconf=0\nsysctl -qw net.ipv6.conf.eth5.accept_ra=0\nip link set dev eth5 mtu 1500\nip link set eth5 up\nip link set eth6 down\nsysctl -qw net.ipv6.conf.eth6.autoconf=0\nsysctl -qw net.ipv6.conf.eth6.accept_ra=0\nip link set dev eth6 mtu 1500\nip link set eth6 up\n\n#\n# Add vtysh.conf file\necho \"service integrated-vtysh-config\" >/etc/frr/vtysh.conf\n\n#\n# Rest of initial configuration done through VTYSH\n#\ncat >/tmp/config <<CONFIG\nhostname dut\n!\nlog file /tmp/logging\n\n!\nip forwarding\nipv6 forwarding\nvrf mgmt\n exit-vrf\n!\nfrr defaults datacenter\n!\ninterface lo\n no shutdown\n ip address 10.0.0.1/32\n ipv6 address 2001:db8:1:1::1/64\n!\ninterface eth1\n no shutdown\n description dut -> x1 [external]\n ip address 10.1.0.1/30\n ipv6 address 2001:db8:3::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ninterface eth2\n no shutdown\n description dut -> x2 [external]\n ip address 10.1.0.5/30\n ipv6 address 2001:db8:3:1::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ninterface eth3\n no shutdown\n description dut -> x3 [external]\n ip address 10.1.0.9/30\n ipv6 address 2001:db8:3:2::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ninterface eth4\n no shutdown\n description dut -> vx1 [external]\n ip address 10.1.0.13/30\n ipv6 address 2001:db8:3:3::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ninterface eth5\n no shutdown\n description dut -> vx2 [external]\n ip address 10.1.0.17/30\n ipv6 address 2001:db8:3:4::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ninterface eth6\n no shutdown\n description dut -> vx3 [external]\n ip address 10.1.0.21/30\n ipv6 address 2001:db8:3:5::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ndo write\nCONF