nk set dev eth2 mtu 1500\nip link set eth2 up\n\n#\n# Add vtysh.conf file\necho \"service integrated-vtysh-config\" >/etc/frr/vtysh.conf\n\n#\n# Rest of initial configuration done through VTYSH\n#\ncat >/tmp/config <<CONFIG\nhostname dut\n!\nlog file /tmp/logging\n\n!\nip forwarding\nipv6 forwarding\nvrf mgmt\n exit-vrf\n!\nfrr defaults datacenter\n!\ninterface lo\n no shutdown\n ip address 10.0.0.42/32\n ipv6 address 2001:db8:42:1::1/128\n!\ninterface eth1\n no shutdown\n description dut -> p_global [external]\n ip address 10.1.0.1/30\n ipv6 address 2001:db8:3::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ninterface eth2\n no shutdown\n description dut -> p_vrf [external]\n ip address 10.1.0.5/30\n ipv6 address 2001:db8:3:1::1/64\n ipv6 nd ra-interval 5\n no ipv6 nd suppress-ra\n!\ninterface lo1\n no shutdown\n description VRF Loopback customer\n ip address 10.2.0.1/32\n ipv6 address 2001:db8:4::1/64\n!\ndo write\nCONFIG\nvtysh -f /tmp/config\n!\nexit 0\n"
}
