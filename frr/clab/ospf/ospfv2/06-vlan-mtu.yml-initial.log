 >/etc/frr/vtysh.conf\n\n#\n# Rest of initial configuration done through VTYSH\n#\ncat >/tmp/config <<CONFIG\nhostname dut\n!\nlog file /tmp/logging\n\n!\nip forwarding\nvrf mgmt\n exit-vrf\n!\nfrr defaults datacenter\n!\ninterface lo\n no shutdown\n ip address 10.0.0.1/32\n!\ninterface eth1\n no shutdown\n description dut -> x3\n ! no ip address\n!\ninterface eth2\n no shutdown\n description [Access VLAN ospf_1] dut -> x1\n ! no ip address\n!\ninterface eth3\n no shutdown\n description [Access VLAN ospf_2] dut -> x2\n ! no ip address\n!\ninterface eth1.502\n no shutdown\n description [SubIf VLAN ospf_3] dut -> x3\n ! no ip address\n!\ninterface vlan500\n no shutdown\n description VLAN ospf_1 (500) -> [x1]\n ip address 172.16.0.1/24\n!\ninterface vlan501\n no shutdown\n description VLAN ospf_2 (501) -> [x2]\n ip address 172.16.1.1/24\n!\ninterface vlan502\n no shutdown\n description VLAN ospf_3 (502) -> [x3]\n ip address 172.16.2.1/24\n!\ndo write\nCONFIG\nvtysh -f /tmp/config\n!\nexit 0\n"
}
