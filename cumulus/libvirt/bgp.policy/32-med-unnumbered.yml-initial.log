g\n#\n# Enable LLDP\n#\necho \"INIT: enabling LLDP\"\ncat <<CONFIG >/etc/lldpd.d/system.conf\nconfigure lldp tx-interval 30\nconfigure lldp tx-hold 3\nconfigure system interface pattern *,!eth0,swp*\nCONFIG\nservice lldpd restart\n"
